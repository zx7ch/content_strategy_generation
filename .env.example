# ==================== Runtime ====================
APP_ENV=development
LOG_LEVEL=INFO
XHS_RUNTIME_SERVICE_NAME=xhs-agent-runtime
XHS_RUNTIME_VERSION=0.1.0
XHS_RUNTIME_API_CONTRACT=local-runtime-v1
# Add the production Vercel domain after the frontend is deployed.
# Example: http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app
XHS_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==================== LLM Providers ====================
LLM_PROVIDER=anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
KIMI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_MODEL=claude-opus-4-6
DEEPSEEK_MODEL=deepseek-chat
MINIMAX_MODEL=abab6.5s-chat
KIMI_MODEL=moonshot-v1-8k

# ==================== Storage ====================
XHS_SQLITE_DB_PATH=./data/xhs_agent.db
XHS_CHROMA_PERSIST_DIR=./data/chroma
POSTGRES_DSN=

# ==================== Frontend Runtime ====================
NEXT_PUBLIC_XHS_API_BASE_URL=http://127.0.0.1:8000
# Workspace and user identity are resolved automatically via GET /workspaces/default.
# No configuration needed for single-deployment mode.
# Optional: set V2_AUTH_TOKEN + V2_AUTH_ENABLED=true on the backend to protect the API.
NEXT_PUBLIC_XHS_AUTH_TOKEN=

# ==================== Spider ====================
XHS_SPIDER_COOKIES=
XHS_SPIDER_MAX_RETRIES=5
XHS_SPIDER_MAX_AUTO_RETRIES=3
XHS_SPIDER_MAX_USER_RETRIES=2
XHS_SPIDER_BACKOFF_BASE=2
XHS_SPIDER_SORT_TYPE=2

# ==================== Quality Threshold ====================
QUALITY_SCORE_THRESHOLD=0.35
XHS_QUALITY_SCORE_THRESHOLD=0.35
XHS_EXPANSION_DOC_COUNT_MAX=10
XHS_EXPANSION_MIN_NEW_UNIQUE_DOCS=3
XHS_EXPANSION_MIN_QUALITY_GAIN=0.05

# ==================== Generation ====================
PARALLEL_TEMPERATURES=[0.3,0.5,0.7,0.9,1.1]
GENERATION_MAX_RETRIES=2
XHS_GENERATION_PARALLEL_SLOTS=5
XHS_GENERATION_DEGRADED_SLOTS=3
NUM_PROPOSALS=10
NUM_FINAL_NOTES=5
XHS_EMBEDDING_REWRITE_THRESHOLD=0.6
XHS_EMBEDDING_WARNING_THRESHOLD=0.3
XHS_LEXICAL_WARNING_THRESHOLD=0.4

# ==================== Budget ====================
XHS_SESSION_TOKEN_BUDGET=120000
LLM_MODEL_STRATEGY=high_quality_model
LLM_MODEL_QUERY_EXPANSION=high_quality_model
LLM_MODEL_PROPOSAL=balanced_model
LLM_MODEL_NOTE_GENERATION=low_cost_model
LLM_MODEL_FALLBACK_GENERIC=balanced_model

# ==================== Session Lifecycle ====================
SESSION_TIMEOUT_MINUTES=30
XHS_SESSION_ALIVE_HOURS=24
XHS_SESSION_FROZEN_AFTER_HOURS=24
XHS_SESSION_PURGE_AFTER_DAYS=10

# ==================== Queue / SSE ====================
XHS_JOB_POLL_INTERVAL_MS=500
XHS_JOB_LEASE_SECONDS=60
XHS_JOB_MAX_RETRIES=5
JOB_RECOVERY_ON_STARTUP=true
XHS_SSE_HEARTBEAT_SECONDS=15
XHS_SSE_REPLAY_LIMIT=500

# ==================== Observability ====================
XHS_METRICS_ROLLING_WINDOW_MINUTES=5
XHS_ALERT_EVALUATOR_INTERVAL_SECONDS=60
XHS_ALERT_JOB_SUCCESS_RATE_MIN=0.99
XHS_ALERT_JOB_RECOVERY_SUCCESS_RATE_MIN=0.99
XHS_ALERT_LLM_P95_LATENCY_MS_MAX=8000
XHS_ALERT_BUDGET_EXCEEDED_COUNT_MAX=5
XHS_ALERT_REINDEX_BACKLOG_COUNT_MAX=20
XHS_ALERT_REINDEX_SUCCESS_RATE_MIN=0.95

# ==================== RAG ====================
RAG_EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5
RAG_CHUNK_MAX_LENGTH=1000
REINDEX_MAX_ATTEMPTS=3
